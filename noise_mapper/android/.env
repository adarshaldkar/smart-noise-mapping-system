# 📱 Noise Mapper Android Configuration

# 🚨 IMPORTANT: Replace this with your computer's Wi-Fi IP Address!
# I detected: 172.25.16.12, but if that doesn't work, check your Wi-Fi settings.
# It usually looks like 192.168.1.x
MQTT_HOST=172.25.16.12

# MQTT Port (Default is 1883)
MQTT_PORT=1883

# Authentication (Leave empty for now)
MQTT_USERNAME=
MQTT_PASSWORD=

# Unique Name for your Phone
USER_ID=my_android_phone

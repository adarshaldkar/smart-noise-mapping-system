# Copy this file to .env and update with your settings

# Your computer's IP address (find with: ipconfig on Windows, ifconfig on Mac/Linux)
# If running on the same device, use: mosquitto
# If running on Android phone, use your computer's local IP (e.g., 192.168.1.12)
MQTT_HOST=192.168.1.12

# MQTT broker port (default: 1883)
MQTT_PORT=1883

# MQTT authentication (leave empty if not using authentication)
MQTT_USERNAME=
MQTT_PASSWORD=

# Unique identifier for this device (e.g., my_phone, android_1, etc.)
USER_ID=my_phone
